rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Common functions
    function isAuthenticated() { return request.auth != null; }
    function isAdmin() { 
      return isAuthenticated() && (
        request.auth.uid == 'oVp72Q285MPhvWq9G6p2HqQ6v3a2' || 
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin')
      ); 
    }
    function isSupplier() { 
      return isAuthenticated() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'supplier'; 
    }

    // =====================================================================
    // LECTURE (READ) :
    // Obligatoire pour le fonctionnement du site. L'architecture actuelle 
    // télécharge toute la base dans "localDB". On doit donc autoriser la lecture.
    // =====================================================================
    match /{document=**} {
      allow read: if true;
    }

    // =====================================================================
    // ÉCRITURE (WRITE) : Sécurité maintenue pour empêcher le piratage
    // =====================================================================
    
    // USERS
    match /users/{userId} {
      allow create: if true;
      allow update: if isAuthenticated() && request.auth.uid == userId;
      allow delete: if isAdmin();
    }

    // SUPPLIERS
    match /suppliers/{supplierId} {
      allow create, delete: if isAdmin();
      allow update: if isAdmin() || (isSupplier() && request.auth.uid == resource.data.ownerId);
    }

    // CATALOG, CATEGORIES, TRAININGS
    match /agent_products/{productId} { allow write: if isAdmin(); }
    match /categories/{categoryId} { allow write: if isAdmin(); }
    match /trainings/{trainingId} { allow write: if isAdmin(); }

    // ORDERS
    match /orders/{orderId} {
      allow create: if isAuthenticated() && request.resource.data.clientId == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.clientId == request.auth.uid;
      allow delete: if isAdmin();
    }
  }
}
